<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Admin — KELLY LIN</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=Inter:wght@300;400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/public/style.css" />
</head>
<body>
<div class="login-wrap">
  <form class="login-card" method="POST" action="/admin/login" autocomplete="off">
    <h1>KELLY LIN</h1>
    <p style="text-align:center; font-size:12px; color:#8a7e6e; letter-spacing:3px; margin-bottom:20px;">ADMIN PANEL</p>
    <input type="password" name="password" placeholder="請輸入密碼" required autofocus />
    <button type="submit">登 入</button>
    <% if (error) { %><div class="err"><%= error %></div><% } %>
  </form>
</div>
</body>
</html>
